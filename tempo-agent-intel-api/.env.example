PORT=3000
HOST=127.0.0.1

# mock  - unpaid requests return HTTP 402, paid test requests use X-Mock-Payment: paid
# tempo - Tempo MPP mode; live handling requires TEMPO_MPP_LIVE_ENABLED=true and runtime preflight
# x402  - scaffolded Base x402 mode; blocked until x402 middleware + recipient wallet are configured
# multi - advertises multiple rails; live verification is blocked until adapters are configured
PAYMENT_MODE=mock
ENABLED_PAYMENT_RAILS=mock

# Public base URL used inside OpenAPI. For local development:
PUBLIC_BASE_URL=http://127.0.0.1:3000

# Keep detailed runtime diagnostics local unless you are actively debugging.
EXPOSE_RUNTIME_READINESS_DETAILS=false

# Live payment modes require Idempotency-Key by default. Set explicitly only if you need to override.
REQUIRE_IDEMPOTENCY_KEY_FOR_PAID=
# Live payment modes require report retrieval proof by default. Keep true in production.
REQUIRE_REPORT_ACCESS_PROOF=

# App-level fixed-window limit for public paid report routes. Keep platform WAF/rate limits too.
REPORT_RATE_LIMIT_ENABLED=
REPORT_RATE_LIMIT_MAX=30
REPORT_RATE_LIMIT_WINDOW_MS=60000
REPORT_RATE_LIMIT_TRUST_PROXY_HEADERS=

# Local file-backed storage. Production autonomous mode should use AGENT_STORAGE_BACKEND=upstash_redis.
AGENT_STORAGE_BACKEND=file
REPORT_STORE_PATH=.data/reports.json
PAYMENT_LEDGER_PATH=.data/payment-events.json
AGENT_STORAGE_REDIS_PREFIX=agent-launch-intel-api
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Mock price display only. Real MPP amounts must be configured before launch.
PRICE_QUICK_USD=0.01
PRICE_STANDARD_USD=0.05
PRICE_DEEP_USD=0.25
MAX_REPORT_PRICE_USD=0.25

# Receiving wallets. These are public addresses only; never put root private keys in runtime env.
RECEIVE_TEMPO_ADDRESS=
RECEIVE_BASE_ADDRESS=
TEMPO_RPC_URL=https://rpc.tempo.xyz
TEMPO_CHAIN_ID=4217
TEMPO_USDC_ADDRESS=0x20c000000000000000000000b9537d11c60e8b50
BASE_USDC_ADDRESS=0x833589fcd6edb6e08f4c7c32d4f71b54bda02913
TEMPO_TOKEN_DECIMALS=6
BASE_TOKEN_DECIMALS=6

# Tempo MPP live runtime. MPP_SECRET_KEY is not a wallet key; it binds server-issued challenges.
TEMPO_MPP_LIVE_ENABLED=false
TEMPO_MPP_DEPS_ROOT=.
TEMPO_MPP_RUNTIME_ENV_PATH=.secrets/mpp-runtime.env
TEMPO_MPP_SECRET_KEY=
TEMPO_MPP_REALM=
TEMPO_MPP_WAIT_FOR_CONFIRMATION=true
TEMPO_MPP_VERIFY_ONCHAIN_ON_REQUEST=true
TEMPO_MPP_SUPPORTED_MODES=push

# Outbound Tempo MPP usage by the agent. Keep disabled until inbound paid service is verified.
OUTBOUND_LIVE_PAYMENTS=false
OUTBOUND_PAYMENT_PROVIDER=remote_signer
MAX_OUTBOUND_PER_CALL_USD=0.05
MAX_OUTBOUND_DAILY_USD=0.50
OUTBOUND_ALLOWED_SERVICES=mpprimo.com
OUTBOUND_DENY_UNKNOWN_SERVICES=true
OUTBOUND_ADMIN_TOKEN=
OUTBOUND_MPPRIMO_AMOUNT_BASE_UNITS=1000
OUTBOUND_MPPRIMO_RECIPIENT=0x908c2f7b58b637ad66f16bb914d884a94dfa00ff

# Remote signer keeps Turnkey/API signing material outside the public agent runtime.
OUTBOUND_SIGNER_BASE_URL=
OUTBOUND_SIGNER_ADMIN_TOKEN=
OUTBOUND_SIGNER_AGENT_ID=agent-launch-intel
OUTBOUND_SIGNER_COMMAND=pay_mpprimo_ratings

ENABLE_OUTBOUND_CRON=false
CRON_SECRET=
OUTBOUND_CRON_IDEMPOTENCY_PREFIX=cron-mpprimo-ratings
OUTBOUND_CRON_REQUIRE_VERIFIED_MANUAL_PAYMENT=true
OUTBOUND_CRON_ARMING_IDEMPOTENCY_KEY=

# Legacy local signer mode. Never put the root wallet private key here.
# Only fill this block when OUTBOUND_PAYMENT_PROVIDER=local_access_key is explicitly approved.
AGENT_ACCESS_KEY_ENV_PATH=.secrets/agent-access-key.env
AGENT_ROOT_ACCOUNT_ADDRESS=
AGENT_ACCESS_KEY_ADDRESS=
AGENT_ACCESS_KEY_PRIVATE_KEY=
AGENT_ACCESS_KEY_EXPIRES_AT=
AGENT_ACCESS_KEY_TOKEN_LIMITS_JSON=
