HOST=127.0.0.1
PORT=3100
PUBLIC_BASE_URL=http://127.0.0.1:3100

# mock is safe for local development. turnkey is blocked until real credentials are configured.
SIGNER_PROVIDER=mock
SIGNER_LEDGER_BACKEND=file
SIGNER_LEDGER_PATH=.data/signer-ledger.json
SIGNER_LEDGER_REDIS_PREFIX=tempo-outbound-signer
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Required for any POST signing route. Keep blank in committed templates.
SIGNER_ADMIN_TOKEN=

# App-level fixed-window limit for admin routes. Keep platform WAF/rate limits too.
SIGNER_ADMIN_RATE_LIMIT_ENABLED=
SIGNER_ADMIN_RATE_LIMIT_MAX=60
SIGNER_ADMIN_RATE_LIMIT_WINDOW_MS=60000
SIGNER_ADMIN_RATE_LIMIT_TRUST_PROXY_HEADERS=

# Public wallet/policy config only. Do not put private keys here.
TEMPO_CHAIN_ID=4217
TEMPO_RPC_URL=https://rpc.tempo.xyz
TEMPO_USDC_ADDRESS=0x20c000000000000000000000b9537d11c60e8b50
TEMPO_TOKEN_DECIMALS=6
AGENT_WALLETS_JSON=[{"agent_id":"agent-launch-intel","wallet_address":"0x1111111111111111111111111111111111111111","tempo_access_key_address":"0x2222222222222222222222222222222222222222","turnkey_sign_with":"","enabled":true,"per_call_limit_base_units":"10000","daily_limit_base_units":"50000","allowed_services":["mpp.browserbase.com"],"allowed_endpoints":["https://mpp.browserbase.com/fetch"],"allowed_recipients":["0x9d27dc344b981264208583a6fc88b8c137d9e4b3"],"allowed_commands":["fetch_browserbase_page"],"allowed_browserbase_fetch_urls":["https://mpp.dev/services"]}]

# Future Turnkey integration. Keep these blank until a Turnkey org is created.
TURNKEY_API_BASE_URL=https://api.turnkey.com
TURNKEY_ORGANIZATION_ID=
TURNKEY_API_PUBLIC_KEY=
TURNKEY_API_PRIVATE_KEY=
